# ra-egress .env — tunnel-provision.ps1 tarafından otomatik oluşturulur.
# Elle oluşturuyorsan aşağıdaki değerleri doldur.
# Bu dosyayı .gitignore'a ekle, asla commit etme.

# Cloudflare Named Tunnel token'ı.
# Kaynak: cloudflared tunnel token <tunnel-adı>
# veya: tunnel-provision.ps1 otomatik yazar.
TUNNEL_TOKEN=

# ra-egress HMAC imza anahtarı — LibEdge proxy Worker ile eşleşmeli.
# Kaynak: setup-staging.ps1 veya admin paneli.
EGRESS_SHARED_SECRET=

# Publisher hostlarına izin verilen regex (Go syntax).
# Tek kurum, birden fazla publisher olabilir — | ile ayır.
# Örnek (JoVE + Wiley):
#   ALLOWED_HOST_REGEX=^(www\.jove\.com|jove\.com|cdn\.jove\.com|api\.wiley\.com)$
ALLOWED_HOST_REGEX=^(www\.jove\.com|jove\.com|cdn\.jove\.com|player\.jove\.com|assets\.jove\.com)$
